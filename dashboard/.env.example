API_URL=http://localhost:8000/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Shared secret with Django (must match INTERNAL_API_SECRET in Django)
INTERNAL_API_SECRET=dev-internal-secret

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Resend — https://resend.com/api-keys
RESEND_API_KEY=
RESEND_AUDIENCE_ID=

# Waitlist mode — set to "true" to redirect /login → / (used before platform launch)
NEXT_PUBLIC_WAITLIST_MODE=true

